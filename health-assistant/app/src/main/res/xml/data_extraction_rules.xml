<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include health data for cloud backup -->
        <include domain="database" path="health_database"/>
        <include domain="sharedpref" path="user_preferences.xml"/>
        
        <!-- Exclude sensitive data -->
        <exclude domain="sharedpref" path="auth_tokens.xml"/>
        <exclude domain="file" path="temp/"/>
        <exclude domain="cache" path="image_cache/"/>
    </cloud-backup>
    
    <device-transfer>
        <!-- Include all user data for device transfer -->
        <include domain="database" path="health_database"/>
        <include domain="sharedpref" path="user_preferences.xml"/>
        <include domain="file" path="exports/"/>
        
        <!-- Exclude temporary files -->
        <exclude domain="cache" path="."/>
        <exclude domain="file" path="temp/"/>
    </device-transfer>
</data-extraction-rules>
